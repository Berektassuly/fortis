# Public Supabase project URL.
# Supabase Dashboard -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# Public anon/publishable API key used by the browser wallet/auth clients.
# Supabase Dashboard -> Project Settings -> API -> Project API keys -> anon / publishable
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Optional storage bucket used for listing cover uploads.
# Keep this aligned with the bucket created by the SQL migrations. The default Fortis bucket is `listings`.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="listings"

# Optional Solana RPC endpoint for wallet adapter and signing flows.
# Use your provider URL from Helius, QuickNode, Triton, Alchemy, etc. If omitted, the app falls back to Solana devnet.
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"

# Server-only service role key.
# Required for Fortis webhook processing and for auto-repairing missing public.users <-> auth.users mappings.
# Supabase Dashboard -> Project Settings -> API -> Project API keys -> service_role
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Base URL of the Rust Fortis engine deployment. No trailing slash required.
# Use the public URL of the backend service running in `backend/`.
FORTIS_ENGINE_URL="https://your-fortis-backend.up.railway.app"

# Path on the Rust backend that accepts listing tokenization requests.
# Keep the default unless the backend exposes a different route.
FORTIS_ENGINE_TOKENIZE_PATH="/listings/tokenize"

# Path on the Rust backend that accepts transfer request submissions.
# Keep the default unless the backend exposes a different route.
FORTIS_ENGINE_TRANSFER_REQUEST_PATH="/transfer-requests"

# Shared bearer token expected by the Rust backend for privileged API calls from the Next.js app.
# Generate a high-entropy secret, for example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then set the exact same value in both marketplace-api and the Rust backend environment.
FORTIS_ENGINE_TOKEN=""

# Shared HMAC secret used to verify `x-fortis-signature` on Fortis webhook callbacks.
# Generate it the same way as FORTIS_ENGINE_TOKEN and configure the identical value on both services.
FORTIS_WEBHOOK_SECRET="replace-with-a-shared-secret"
