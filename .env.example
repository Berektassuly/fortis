# Root environment for the Fortis monorepo.
# Copy this file to ./.env. The backend auto-loads it from the repo root,
# even when `cargo run` is executed from ./backend.

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/fortis_rwa_backend

# Solana / issuer wallet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Accepts either a Base58-encoded secret or a JSON array copied from a Solana keypair file.
ISSUER_PRIVATE_KEY=YOUR_BASE58_ENCODED_PRIVATE_KEY_HERE

# Range Protocol
RANGE_API_KEY=
# RANGE_API_URL=https://api.range.org/v1
# RANGE_RISK_THRESHOLD=6

# HTTP server
HOST=0.0.0.0
PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# Background worker
ENABLE_BACKGROUND_WORKER=true

# Jito bundle submission (QuickNode only)
USE_JITO_BUNDLES=false
JITO_TIP_LAMPORTS=10000
# JITO_REGION=ny

# Webhook authentication
# HELIUS_WEBHOOK_SECRET=your-helius-webhook-secret
# QUICKNODE_WEBHOOK_SECRET=your-quicknode-webhook-secret

# Stale transaction crank
ENABLE_STALE_CRANK=true
CRANK_POLL_INTERVAL_SECS=60
CRANK_STALE_AFTER_SECS=90
CRANK_BATCH_SIZE=20

# Logging
RUST_LOG=info,tower_http=debug,sqlx=warn
